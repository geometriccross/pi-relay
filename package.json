{
  "name": "pi-relay",
  "version": "0.1.0",
  "description": "Pi extension for parent-child shell session communication",
  "main": "src/index.ts",
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "test": "tsx --test \"test/**/*.test.ts\"",
    "test:e2e": "npm run build && PI_RELAY_RUN_E2E=1 tsx --test \"test/e2e/pi-relay.e2e.test.ts\"",
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "latest",
    "@earendil-works/pi-tui": "latest",
    "@types/node": "^22.0.0",
    "fast-check": "^4.8.0",
    "tsx": "^4.20.0",
    "typebox": "latest",
    "typescript": "^5.7.0"
  }
}
